# API Configuration
NEXT_PUBLIC_API=https://icms.frontiertech.org/graphql
NEXT_PUBLIC_DATA=https://icms.frontiertech.org
NEXT_PUBLIC_SOCKET=wss://icms.frontiertech.org/graphql

# Mapbox Configuration
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Email Configuration (Resend)
RESEND_API_KEY=re_your_resend_api_key_here

# Contact Email
# Primary email for receiving contact form submissions
CONTACT_EMAIL=contact@icapital.com
# Public contact email (for client-side use if needed)
NEXT_PUBLIC_CONTACT_EMAIL=contact@icapital.com

# Domain Configuration
NEXT_PUBLIC_DOMAIN=icapital.com

# Environment
NODE_ENV=development
